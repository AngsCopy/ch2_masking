  <Routines>
    <Routine name="Intro">
      <RoutineSettingsComponent name="Intro" plugin="None">
        <Param val="none" valType="str" updates="None" name="backgroundFit"/>
        <Param val="" valType="str" updates="None" name="backgroundImg"/>
        <Param val="$[0,0,0]" valType="color" updates="None" name="color"/>
        <Param val="rgb" valType="str" updates="None" name="colorSpace"/>
        <Param val="" valType="str" updates="constant" name="desc"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="" valType="code" updates="None" name="durationEstim"/>
        <Param val="False" valType="code" updates="None" name="forceNonSlip"/>
        <Param val="Intro" valType="code" updates="None" name="name"/>
        <Param val="True" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="constant" name="skipIf"/>
        <Param val="duration (s)" valType="str" updates="None" name="stopType"/>
        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="False" valType="bool" updates="None" name="useWindowParams"/>
      </RoutineSettingsComponent>
      <CodeComponent name="initial_setup" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="// Parameters - change these based on the needs of the experiment&amp;#10;const min_num = 1; // Minimum value of stimulus parameter&amp;#10;const max_num = 80; // Maximum value of stimulus parameter&amp;#10;const rand_min = -10;&amp;#10;const rand_max = 10;&amp;#10;const build_type = 1; // How should factor combinations be generated?&amp;#10;// 1 = Automatic&amp;#10;// 2 = Manual (note that loops and param_order is ignored)&amp;#10;const loops = 1; // How many times should the conditions be repeated?&amp;#10;var independents = [];&amp;#10;   independents[&quot;start_first&quot;] = [];&amp;#10;   independents[&quot;env&quot;] = [2, 3, 4];&amp;#10;   independents[&quot;start_level&quot;] = [10];&amp;#10;   independents[&quot;start_position&quot;] = [0.38, 0.405];&amp;#10;const start_first_flat = [60]; // Parameter values for the first number stimulus with flat envelope (array of values)&amp;#10;const start_first_perc = [60]; // Parameter values for the first number stimulus with percussive envelope (array of values)&amp;#10;const param_order = 1; // If 1, trials are ordered by start_first. If 2, they are ordered by env.&amp;#10;const step_size_up = [16,8,4,2]; // How large should increases in intensity be across the experiment? (array of values)&amp;#10;const step_size_down = [16,8,4,2]; // How large should decreases in intensity be across the experiment? (array of values)&amp;#10;const freq_step_up = [1]; // How many consecutive (same response) trials should lead to an increase in step size across the experiment? (array of values)&amp;#10;const freq_step_down = [2]; // How many consecutive (same response) trials should lead to a decrease in step size across the experiment? (array of values)&amp;#10;const order_mode = 6; // See below for options:&amp;#10;// 1 = Fixed random staircase order - A random order of staircase presentation is determined at the beginning of the experiment and looped.&amp;#10;// 2 = Fluid random staircase order - A random order of staircase presentation is determined everytime a response has been provided on all staircases.&amp;#10;// 3 = Ordered - Staircases are presented sequentially in a single block.&amp;#10;// 4 = Randomly ordered blocks - Staircases are presented in randomly ordered, individual blocks (not interleaved).&amp;#10;// 5 = Sequential block - Staircases are presented in individual blocks (not interleaved).&amp;#10;// 6 = Interleaved blocks - Staircases are presented in a specified number of pairs within randomly ordered blocks&amp;#10;const pair_num = 3; // (order_mode must equal 6) - How many pairs of staircases do you want to be in each block?&amp;#10;const blockrandom = 1; // (order_mode must equal 6) - Should order of staircases be completely random?&amp;#10;const stop_mode = 1; // See options below:&amp;#10;// 0 = Participants complete all trials in all staircases.&amp;#10;// 1 = Staircases are terminated after they reach a total number of reversals.&amp;#10;// 2 = Staircases are terminated after they reach a consecutive number of reversals.&amp;#10;const stop_num = 8; // In stop_mode 1 and 2, number of trials that causes termination.&amp;#10;const max_trials = 100; // Set the maximum number of trials for each staircase (so the whole experiment will have a maximum of (max_trials * length of start_first * length of env) trials)&amp;#10;const ext = &quot;wav&quot;; // File extension and directory name for stimuli&amp;#10;const correctanswer = 1; // If 0, then there is no correct response in this experiment. If 1, then correct responses are used for determining steps and reversals.&amp;#10;const rand_stim = 0; // If 0, standard is always presented first in a trial. If 1, order of standard and comparitor is randomised.&amp;#10;const breaks = 0; // If set to 1, participants will be given opportunities to take breaks.&amp;#10;const break_num = 10; // Number of trials required for a break to occur.&amp;#10;const env_types = [[&quot;flat&quot;, &quot;perc&quot;], [&quot;perc&quot;, &quot;flat&quot;], [&quot;flat&quot;, &quot;flat&quot;], [&quot;perc&quot;, &quot;perc&quot;], [&quot;revperc&quot;, &quot;revperc&quot;]]; // Envelope combo types&amp;#10;&amp;#10;// Global variables - avoid changing these&amp;#10;var skip = 0; // Used for skipping brief in debugging&amp;#10;var skipval = [ &quot;s&quot;, &quot;k&quot;, &quot;i&quot;, &quot;p&quot;, &quot;space&quot; ]; // Skip the Goldsmith keys&amp;#10;var first; // The value of the first stimulus&amp;#10;var second; // The value of the second stimulus (if applicable)&amp;#10;var trial_index; // Which interleaved trial is currently being used?&amp;#10;var trial_indexer = 0; // Index value for trial_index&amp;#10;var last_result_array = []; // Was the last answer up or down?&amp;#10;var flat_array = start_first_flat; // Array made from first values and envelope combinations&amp;#10;var perc_array = start_first_perc; // Array made from first values and envelope combinations&amp;#10;//var level_array = start_level; // Array made from difference values and envelope combinations&amp;#10;//var env_array = env; // Array made from envelope values and first/difference combinations&amp;#10;var level_array; // Array made from difference values and envelope combinations&amp;#10;var env_array; // Array made from envelope values and first/difference combinations&amp;#10;var step_index_array = []; // Determines the step size within each staircase&amp;#10;var freq_index_array = []; // Keeps track the number of consecutive responses that leads to a change for each staircase&amp;#10;var trial_index_array = []; // Keeps track of the order of staircases&amp;#10;var up_counter_array = []; // Counter for consecutive up responses in each staircase&amp;#10;var down_counter_array = []; // Counter for consecutive down responses in each staircase&amp;#10;var l_reversal_array = []; // Keeps track of whether the last trial was a reversal in each staircase&amp;#10;var n_reversal_array = []; // Keeps track of the total number of reversals in each staircase&amp;#10;var c_reversal_array = []; // Keeps track of consecutive reversals in each staircase&amp;#10;var c_stop_array = []; // Keeps track of consecutive reversals once step size is at minimum (stop parameter is now imminent).&amp;#10;var block_array = []; // Array of trial indices within each block in an interleaved blocks design.&amp;#10;var block_index = 0; // Keeps track of which interleaved block is active&amp;#10;var sound1_file; // The first sound file&amp;#10;var sound2_file; // The second sound file&amp;#10;var sound1 = sound1_file; // The first sound variable&amp;#10;var sound2 = sound2_file; // The second sound variable&amp;#10;var stim_order = &quot;SC&quot;; // Order of standard/comparitor in trial for dataset&amp;#10;var num_trials; // Number of trials in the experiment&amp;#10;var trial_counter_array = []; // Counts the total number of trials passed in each staircase&amp;#10;var resp; // Substitute for key response or correct response&amp;#10;var break_time = false; // Breaktimes for interleaved blocks design&amp;#10;var time;&amp;#10;var current_direction;&amp;#10;var last_direction_array = [];&amp;#10;var first_rev_array = [];&amp;#10;var min_level; // Minimum value of stimulus intensity&amp;#10;var max_level; // Maximum value of stimulus intensity&amp;#10;var keys;&amp;#10;var values;&amp;#10;var offset1;&amp;#10;var offset2;&amp;#10;var offset3;&amp;#10;var randnum;&amp;#10;var adjust;&amp;#10;&amp;#10;&amp;#10;// Functions&amp;#10;&amp;#10;// Fisher-Yates Shuffler - Randomly orders a list&amp;#10;function fisher_yate(array) {&amp;#10;    for (let i = array.length -1; i &gt; 0; i--) { // Loops around the length of a list&amp;#10;        let j = Math.floor(Math.random() * i) // Random position for each item in the list&amp;#10;        let k = array[i] // Item from the list&amp;#10;        array[i] = array[j] // Foundation i is moved to position j&amp;#10;        array[j] = k // Item from list is placed on foundation&amp;#10;        }&amp;#10;    }&amp;#10;&amp;#10;&amp;#10;function make_condition(array) {&amp;#10;  let conds = [];&amp;#10;  let v = array.map(function f(arr) {return arr.length});&amp;#10;  let fact = v.reduce(function f(t, n) {return t * n});&amp;#10;  let factperm = fact;&amp;#10;  let newtem;&amp;#10;    for (let i = 0; i &lt; (array.length); i++) {&amp;#10;      let temp = [];&amp;#10;      for (let j = 0; j &lt; (array[i].length); j++) {&amp;#10;        while (temp.length &lt; ((fact / array[i].length) * (j + 1))) {&amp;#10;          temp.push(array[i][j]);&amp;#10;        }&amp;#10;      }&amp;#10;    newtem = [...temp];&amp;#10;    while (temp.length &lt; factperm) {&amp;#10;      temp.push(...newtem);&amp;#10;    }&amp;#10;    conds[i] = temp;&amp;#10;    if ((fact / array[i].length) &lt; fact) {&amp;#10;      fact = fact / array[i].length;&amp;#10;    }&amp;#10;    }&amp;#10;    return conds;&amp;#10;}&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="import random&amp;#10;min_num = 1&amp;#10;max_num = 50&amp;#10;diff = 8&amp;#10;step_size_up = 1&amp;#10;step_size_down = 1&amp;#10;freq_step_up = 1&amp;#10;freq_step_down = 1&amp;#10;step_up_counter = 0&amp;#10;step_down_counter = 0&amp;#10;def second_number(first_num, second_num):&amp;#10;    second = -1&amp;#10;    while second &lt; min_num or second &gt; max_num:&amp;#10;        rbool = random.randint(1,2)&amp;#10;        if rbool == 1:&amp;#10;            second = first_num + second_num&amp;#10;        else:&amp;#10;            second = first_num - second_num&amp;#10;    return second" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="independents[&quot;start_first&quot;] = Array(start_first_flat.length).fill().map((element, index) =&gt; index);&amp;#10;&amp;#10;keys = Object.keys(independents);&amp;#10;values = Object.values(independents);&amp;#10;&amp;#10;conditions = make_condition(values);&amp;#10;&amp;#10;&amp;#10;flat_array = [];&amp;#10;perc_array = [];&amp;#10;for (let i = 0; i &lt; conditions[1].length; i++) {&amp;#10;  flat_array[i] = start_first_flat[conditions[keys.indexOf(&quot;start_first&quot;)][i]];&amp;#10;  perc_array[i] = start_first_perc[conditions[keys.indexOf(&quot;start_first&quot;)][i]];&amp;#10;}&amp;#10;&amp;#10;&amp;#10;env_array = conditions[keys.indexOf(&quot;env&quot;)];&amp;#10;level_array = conditions[keys.indexOf(&quot;start_level&quot;)];&amp;#10;position_array = conditions[keys.indexOf(&quot;start_position&quot;)];&amp;#10;&amp;#10;//if (build_type == 2) {&amp;#10;//    flat_array = start_first_flat;&amp;#10;//    perc_array = start_first_perc;&amp;#10;//    level_array = start_level;&amp;#10;//    env_array = env;&amp;#10;//    }&amp;#10;&amp;#10;// Add number of loops&amp;#10;if (build_type == 1) {&amp;#10;    for (let i = 1; i &lt; loops; i++) {&amp;#10;        flat_array = flat_array.concat(flat_array);&amp;#10;        perc_array = perc_array.concat(perc_array);&amp;#10;        level_array = level_array.concat(level_array); &amp;#10;        env_array = env_array.concat(env_array);&amp;#10;        }&amp;#10;    }&amp;#10;&amp;#10;// Create a list of nested arrays for interleaved blocked designs&amp;#10;for (let i = 0; i &lt; (flat_array.length / pair_num); i++) {&amp;#10;  block_array.push([]);&amp;#10;}&amp;#10;&amp;#10;&amp;#10;if (blockrandom == 1) {&amp;#10;  var blockrandlist = [];&amp;#10;  for (let i = 0; i &lt; flat_array.length; i++) {&amp;#10;    blockrandlist.push(i);&amp;#10;  }&amp;#10;  fisher_yate(blockrandlist);&amp;#10;  fisher_yate(blockrandlist);&amp;#10;}&amp;#10;&amp;#10;// Fill nested arrays with trial indices&amp;#10;var id = 0;&amp;#10;for (let i = 0; i &lt; flat_array.length; i++) {&amp;#10;  if (blockrandom == 1) {&amp;#10;    block_array[id].push(blockrandlist[i]);&amp;#10;  } else {&amp;#10;  block_array[id].push(i);&amp;#10;  }&amp;#10;  if ((i + 1) % pair_num == 0) {&amp;#10;    id = id + 1;&amp;#10;  }&amp;#10;}&amp;#10;&amp;#10;if (block_array.length == 2) {&amp;#10;    let coin = Math.floor(Math.random() * 2) + 1; // Flip a coin&amp;#10;    if (coin == 1) {&amp;#10;        block_array = [block_array[1], block_array[0]];&amp;#10;        }&amp;#10;    } else {&amp;#10;        fisher_yate(block_array); // Randomise block order&amp;#10;        fisher_yate(block_array);&amp;#10;        }&amp;#10;&amp;#10;// Creates an array of 0s for a number of necessary variables&amp;#10;for (let i = 0; i &lt; flat_array.length; i++) {&amp;#10;  step_index_array.push(0);&amp;#10;  freq_index_array.push(0);&amp;#10;  n_reversal_array.push(0);&amp;#10;  c_reversal_array.push(0);&amp;#10;  up_counter_array.push(0);&amp;#10;  down_counter_array.push(0);&amp;#10;  trial_counter_array.push(0);&amp;#10;  c_stop_array.push(0);&amp;#10;  last_direction_array.push(0);&amp;#10;  first_rev_array.push(0);&amp;#10;}&amp;#10;&amp;#10;// Creates an array of -1s for the last reversal tracker (cannot use 0 for this one)&amp;#10;for (let i = 0; i &lt; flat_array.length; i++) {&amp;#10;  l_reversal_array.push(-1);&amp;#10;  last_result_array.push(-1);&amp;#10;}&amp;#10;&amp;#10;// Creates an array of ascending numbers to represent different staircases&amp;#10;if (order_mode != 6) {&amp;#10;    for (let i = 0; i &lt; flat_array.length; i++) {&amp;#10;        trial_index_array.push(i);&amp;#10;        }&amp;#10;    } else {&amp;#10;        trial_index_array = block_array[0]&amp;#10;        }&amp;#10;&amp;#10;// When any random elements are involved in terms of staircase order, this shuffles the order&amp;#10;if (order_mode != 3 || order_mode != 5) {&amp;#10;  fisher_yate(trial_index_array);&amp;#10;  fisher_yate(trial_index_array);&amp;#10;}&amp;#10;&amp;#10;// In blocked orders, this sets the trial_array to the first position right from the start.&amp;#10;if (order_mode &gt; 2 &amp;&amp; order_mode &lt; 6) {&amp;#10;    trial_indexer = 1;&amp;#10;    trial_index = trial_index_array[trial_indexer -1];&amp;#10;    }   &amp;#10;&amp;#10;// Set maximum number of trials&amp;#10;num_trials = (max_trials * flat_array.length);" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="initial_setup" valType="code" updates="None" name="name"/>
      </CodeComponent>
