    <LoopInitiator loopType="TrialHandler" name="LikertLoop">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[OrderedDict([('Question', 'I spend a lot of my free time doing music-related activities.')]), OrderedDict([('Question', 'I sometimes choose music that can trigger shivers down my spine.')]), OrderedDict([('Question', 'I enjoy writing about music, for example on blogs and forms.')]), OrderedDict([('Question', &quot;If somebody starts singing a song I don't know, I can usually join in.&quot;)]), OrderedDict([('Question', 'I am able to judge whether someone is a good singer or not.')]), OrderedDict([('Question', &quot;I usually know when I'm hearing a song for the first time.&quot;)]), OrderedDict([('Question', 'I can sing or play music from memory.')]), OrderedDict([('Question', &quot;I'm intrigued by musical styles I'm not familiar with and want to find out more.&quot;)]), OrderedDict([('Question', 'Pieces of music rarely evoke emotions for me.')]), OrderedDict([('Question', 'I am able to hit the right notes when I sing along with a recording.')]), OrderedDict([('Question', 'I find it difficult to spot mistakes in a performance of a song even if I know the tune.')]), OrderedDict([('Question', 'I can compare and discuss differences between two performances or versions of the same piece of music.')]), OrderedDict([('Question', 'I have trouble recognizing a familiar song when played in a different way or by a different performer.')]), OrderedDict([('Question', 'I have never been complimented for my talents as a musical performer.')]), OrderedDict([('Question', 'I often read or search the internet for things related to music.')]), OrderedDict([('Question', 'I often pick certain music to motivate or excite me.')]), OrderedDict([('Question', 'I am not able to sing in harmony when somebody is singing a familiar tune.')]), OrderedDict([('Question', 'I can tell when people sing or play out of time with the beat.')]), OrderedDict([('Question', 'I am able to identify what is special about a given musical piece.')]), OrderedDict([('Question', 'I am able to talk about the emotions that a piece of music evokes for me.')]), OrderedDict([('Question', 'I don’t spend much of my disposable income on music.')]), OrderedDict([('Question', 'I can tell when people sing or play out of tune.')]), OrderedDict([('Question', 'When I sing, I have no idea whether I’m in tune or not.')]), OrderedDict([('Question', 'Music is kind of an addiction for me - I couldn’t live without it.')]), OrderedDict([('Question', 'I don’t like singing in public because I’m afraid that I would sing wrong notes.')]), OrderedDict([('Question', 'When I hear a piece of music I can usually identify its genre.')]), OrderedDict([('Question', 'I would not consider myself a musician.')]), OrderedDict([('Question', 'I keep track of new music that I come across (e.g. new artists or recordings).')]), OrderedDict([('Question', 'After hearing a new song two or three times, I can usually sing it by myself.')]), OrderedDict([('Question', 'I only need to hear a new tune once and I can sing it back hours later')]), OrderedDict([('Question', 'Music can evoke my memories of past people and places.')])]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="csv/likertLoopPrompts.csv" valType="file"/>
