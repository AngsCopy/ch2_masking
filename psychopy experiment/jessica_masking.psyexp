        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="LETTER OF INFORMATION / CONSENT&amp;#10;&amp;#10;Studying the masking of tones in different sound contexts&amp;#10;&amp;#10;&amp;#10;Principal Investigator: Dr. Michael Schutz&amp;#10;&amp;#10;School of the Arts&amp;#10;McMaster University&amp;#10;Hamilton, Ontario, Canada&amp;#10;(905) 525-9140 ext. 23159&amp;#10;E-mail: schutz@mcmaster.ca&amp;#10;Web: www.maplelab.net&amp;#10;&amp;#10;&amp;#10;Research Sponsor: McMaster University&amp;#10;&amp;#10;Purpose of the Study: Our auditory system must work hard to discriminate different sounds. One of the difficulties it faces is masking - when one sound obscures another. This study will explore this by comparing tones of different types.&amp;#10;&amp;#10;&amp;#10;Procedures involved in the Research: On each trial, you will listen to three white noise tones, played one after the other. You must then say which tone possessed a distinct target tone, by using either the ‘1’, ‘2’, or '3' key respectively. You will also complete a questionnaire on your demographics and musical experience.&amp;#10;&amp;#10;&amp;#10;We anticipate that this experiment will take approximately 30 minutes (can vary based on task engagement).&amp;#10;&amp;#10;Press SPACE to continue..." valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>
        <Param val="" valType="code" updates="None" name="validator"/>
        <Param val="" valType="num" updates="constant" name="wrapWidth"/>
