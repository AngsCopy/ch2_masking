        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="if ((mouse.isPressedIn(targetpolygon))) {&amp;#10;    play_sound(&quot;wav/target_80.wav&quot;, 100);&amp;#10;}&amp;#10;&amp;#10;if ((mouse.isPressedIn(flatpolygon))) {&amp;#10;    play_sound(&quot;wav/flat_masker.wav&quot;, 500);&amp;#10;}&amp;#10;&amp;#10;if ((mouse.isPressedIn(percpolygon))) {&amp;#10;    play_sound(&quot;wav/perc_masker.wav&quot;, 500);&amp;#10;}&amp;#10;&amp;#10;if ((mouse.isPressedIn(revpolygon))) {&amp;#10;    play_sound(&quot;wav/revperc_masker.wav&quot;, 500);&amp;#10;}" valType="extendedCode" updates="constant" name="Each JS Frame"/>
