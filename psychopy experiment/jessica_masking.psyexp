      <CodeComponent name="textInput2" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="modify = false;&amp;#10;genderInput.text = &quot;&quot;;&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="modify = False&amp;#10;genderInput.text = ''&amp;#10;event.clearEvents('keyboard')" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Both" valType="str" updates="None" name="Code Type"/>
        <Param val="keys = event.getKeys()&amp;#10;if len(keys):&amp;#10;    if 'space' in keys:&amp;#10;        genderInput.text = genderInput.text + ' '&amp;#10;    elif 'backspace' in keys:&amp;#10;        genderInput.text = genderInput.text[:-1]&amp;#10;    elif 'lshift' in keys or 'rshift' in keys:&amp;#10;        modify = True&amp;#10;    elif 'return' in keys:&amp;#10;        continueRoutine = False&amp;#10;    elif 'period' in keys:&amp;#10;        genderInput.text = genderInput.text + '.'&amp;#10;    elif 'comma' in keys:&amp;#10;        genderInput.text = genderInput.text + ','&amp;#10;    elif 'semicolon' in keys:&amp;#10;        genderInput.text = genderInput.text + ';'&amp;#10;    elif 'bracketleft' in keys:&amp;#10;        genderInput.text = genderInput.text + '['&amp;#10;    elif 'bracketright' in keys:&amp;#10;        genderInput.text = genderInput.text + ']'&amp;#10;    elif 'period' in keys:&amp;#10;        genderInput.text = genderInput.text + ';'&amp;#10;    elif 'slash' in keys:&amp;#10;        genderInput.text = genderInput.text + '/'&amp;#10;    elif 'backslash' in keys:&amp;#10;        genderInput.text = genderInput.text + '\ '&amp;#10;    elif 'minus' in keys:&amp;#10;        genderInput.text = genderInput.text + '-'&amp;#10;    elif 'equal' in keys:&amp;#10;        genderInput.text = genderInput.text + '='&amp;#10;    elif 'apostrophe' in keys:&amp;#10;        genderInput.text = genderInput.text + '&quot;'&amp;#10;    elif 'quoteleft' in keys:&amp;#10;        genderInput.text = genderInput.text + '`'&amp;#10;    elif 'escape' in keys:&amp;#10;        genderInput.text = genderInput.text ='Thank You'&amp;#10;    elif '1' in keys and modify:&amp;#10;        genderInput.text = genderInput.text +'!'&amp;#10;        modify = False&amp;#10;    elif 'slash' in keys and modify:&amp;#10;        genderInput.text = genderInput.text +'??'&amp;#10;        modify = False&amp;#10;    elif '9' in keys and modify:&amp;#10;        genderInput.text = genderInput.text +'('&amp;#10;        modify = False&amp;#10;    elif '0' in keys and modify:&amp;#10;        genderInput.text = genderInput.text +')'&amp;#10;        modify = False&amp;#10;    elif  modify and 'semicolon' in keys:&amp;#10;        genderInput.text = genderInput.text +':'&amp;#10;        modify = False&amp;#10;    else:&amp;#10;        if modify:&amp;#10;            genderInput.text = genderInput.text + keys[0].upper()&amp;#10;            modify = False&amp;#10;        else:&amp;#10;            genderInput.text = genderInput.text + keys[0]" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="let theseKeys = psychoJS.eventManager.getKeys();&amp;#10;if (theseKeys.length &gt; 0) {  // at least one key was pressed&amp;#10;  textAdd = theseKeys[theseKeys.length-1]; &amp;#10;  }&amp;#10;&amp;#10;&amp;#10;if (textAdd === 'return') {&amp;#10;    textAdd = '';  // Add nothing&amp;#10;    continueRoutine = false;&amp;#10;} else if (textAdd === 'space') {&amp;#10;    textAdd = ' ';  // Add a space&amp;#10;} else if (textAdd === 'period') {&amp;#10;    textAdd = '.';  &amp;#10;} else if (textAdd === 'comma') {&amp;#10;    textAdd = ',';  &amp;#10;} else if (textAdd === 'semicolon') {&amp;#10;    textAdd = ';';  &amp;#10;} else if (textAdd === 'bracketleft') {&amp;#10;    textAdd = ' ';  &amp;#10;} else if (textAdd === 'bracketright') {&amp;#10;    textAdd = ']';  &amp;#10;} else if (textAdd === 'slash') {&amp;#10;    textAdd = '/'; &amp;#10;} else if (textAdd === 'backslash') {&amp;#10;    textAdd = '\ '; &amp;#10;} else if (textAdd === 'minus') {&amp;#10;    textAdd = '-'; &amp;#10;} else if (textAdd === 'space') {&amp;#10;    textAdd = ' ';  &amp;#10;} else if (textAdd === 'equal') {&amp;#10;    textAdd = '=';  &amp;#10;} else if (textAdd === 'apostrophe') {&amp;#10;    textAdd = '\''; &amp;#10;} else if (textAdd === 'quoteleft') {&amp;#10;    textAdd = '`'; &amp;#10;} else if (textAdd === '1' &amp;&amp; modify) {&amp;#10;    textAdd = '!';  // Add a space&amp;#10;} else if (textAdd === 'backspace') {&amp;#10;    genderInput.text = genderInput.text.slice(0, -1);&amp;#10;    textAdd = undefined;&amp;#10;} else if (['lshift', 'rshift'].includes(textAdd)) {&amp;#10;    modify = true;&amp;#10;} else if (textAdd !== undefined) {&amp;#10;    if (modify) {&amp;#10;        genderInput.text = genderInput.text + textAdd.toUpperCase();&amp;#10;        modify = false;&amp;#10;    } else {&amp;#10;        genderInput.text = genderInput.text + textAdd&amp;#10;    }&amp;#10;    textAdd = undefined;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="psychoJS.experiment.addData(&quot;typedWord&quot;, genderInput.text)&amp;#10;genderInput.setText('')  // empty the onscreen text ready for next input&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="thisExp.addData(&quot;typedWord&quot;, genderInput.text)" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="textInput2" valType="code" updates="None" name="name"/>
      </CodeComponent>
