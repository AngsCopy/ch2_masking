        <Param val="&quot;   Completely Disagree    &quot;,&quot;        Strongly Disagree   &quot;,&quot;Disagree&quot;, &quot;Neutral&quot;, &quot;Agree&quot;,&quot;Strongly Agree&quot;,&quot;Completely Agree&quot;" valType="list" updates="constant" name="labels"/>
