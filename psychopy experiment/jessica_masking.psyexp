        <Param val="var delay = 0;&amp;#10;play_sound = function(wav_path, x) {&amp;#10;    var example_sound = new sound.Sound({&quot;win&quot;: psychoJS.window, &quot;value&quot;: wav_path, &quot;volume&quot;: 1.0});&amp;#10;    if (delay == 0) {&amp;#10;        example_sound.play();&amp;#10;        delay = 1;&amp;#10;        setTimeout(function() { delay = 0 }, x);&amp;#10;        }&amp;#10;    }&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
