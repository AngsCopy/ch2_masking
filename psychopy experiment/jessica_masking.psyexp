      <CodeComponent name="trial_setup" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="// Pre-trial organisation&amp;#10;current_direction = 0;&amp;#10;if ((order_mode == 2 || order_mode == 6) &amp;&amp; trial_indexer == trial_index_array.length) { // In fully random staircase order, the order is shuffled at every reset.&amp;#10;    fisher_yate(trial_index_array);&amp;#10;    fisher_yate(trial_index_array);&amp;#10;    }&amp;#10;if ((order_mode &lt; 3 || order_mode == 6) &amp;&amp; trial_indexer &lt; trial_index_array.length) { // In non-blocked orders, this increases the staircase index at the beginning of each trial&amp;#10;    trial_indexer += 1;&amp;#10;    trial_index = trial_index_array[trial_indexer - 1];&amp;#10;    } else if (order_mode &lt; 4 || order_mode == 6) { // When the highest staircase index is reached, it is reset back to the beginning&amp;#10;        trial_indexer = 1;&amp;#10;        trial_index = trial_index_array[trial_indexer - 1];&amp;#10;        }&amp;#10;&amp;#10;if (env_types[env_array[trial_index]][1] == &quot;perc&quot;) {&amp;#10;    min_level = (min_num - perc_array[trial_index]);&amp;#10;    max_level = (max_num - perc_array[trial_index]);&amp;#10;    } else {&amp;#10;        min_level = (min_num - flat_array[trial_index]);&amp;#10;        max_level = (max_num - flat_array[trial_index]);&amp;#10;        }&amp;#10;&amp;#10;trial_counter_array[trial_index] += 1; // Add to total trial count for each staircase&amp;#10;&amp;#10;// Decide first and second value when envelope is identical&amp;#10;if (env_types[env_array[trial_index]][0] == env_types[env_array[trial_index]][1]) {&amp;#10;    if (env_types[env_array[trial_index]][0] == &quot;perc&quot;) {&amp;#10;        first = perc_array[trial_index];&amp;#10;        second = perc_array[trial_index] + level_array[trial_index];&amp;#10;        } else {&amp;#10;            first = flat_array[trial_index];&amp;#10;            second = flat_array[trial_index] + level_array[trial_index];&amp;#10;            }&amp;#10;        }&amp;#10;&amp;#10;// Decide first and second value when envelope is different (adjust percussive tone)&amp;#10;if (env_types[env_array[trial_index]][0] != env_types[env_array[trial_index]][1]) {&amp;#10;    if (env_types[env_array[trial_index]][0] == &quot;perc&quot;) {&amp;#10;        first = perc_array[trial_index];&amp;#10;        second = flat_array[trial_index] + level_array[trial_index];&amp;#10;        } else {&amp;#10;            first = flat_array[trial_index];&amp;#10;            second = perc_array[trial_index] + level_array[trial_index];&amp;#10;            }&amp;#10;        }&amp;#10;&amp;#10;if ((second &lt; min_num)) { // Insurance if second number exceeds boundaries&amp;#10;    second = min_num;&amp;#10;    level_array[trial_index] = min_level;&amp;#10;    } else if ((second &gt; max_num)) {&amp;#10;        second = max_num;&amp;#10;        level_array[trial_index] = max_level;&amp;#10;        }&amp;#10;&amp;#10;// Create pathway to sound file.&amp;#10;sound1_file = String(ext + &quot;/&quot; + env_types[env_array[trial_index]][0] + &quot;_&quot; + first + &quot;.&quot; + ext); // First sound file&amp;#10;sound2_file = String(ext + &quot;/&quot; + env_types[env_array[trial_index]][1] + &quot;_&quot; + second + &quot;.&quot; + ext); // Second sound file&amp;#10;&amp;#10;if ((rand_stim == 0)) {&amp;#10;    sound1 = sound1_file;&amp;#10;    sound2 = sound2_file;&amp;#10;    }&amp;#10;&amp;#10;// If rand_stim is enabled, jumble the order of the standard and comparitor sound&amp;#10;if ((rand_stim == 1)) {&amp;#10;    let coin = Math.floor(Math.random() * 2) + 1; // Flip a coin&amp;#10;    if ((coin == 1)) { // Standard then comparitor&amp;#10;        sound1 = sound1_file;&amp;#10;        sound2 = sound2_file;&amp;#10;        stim_order = &quot;SC&quot;;&amp;#10;        } else { // Comparitor then standard&amp;#10;            sound1 = sound2_file;&amp;#10;            sound2 = sound1_file;&amp;#10;            stim_order = &quot;CS&quot;;&amp;#10;            }&amp;#10;        }" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="first = random.randint(min_num, max_num)&amp;#10;second = second_number(first, diff)&amp;#10;if first &lt; second:&amp;#10;    correct = 2&amp;#10;else:&amp;#10;    correct = 1" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="if (correctans == 0) { // Which kind of response is being used?&amp;#10;    var resp = (key_resp.keys - 1);&amp;#10;//    var resp = 1;&amp;#10;    } else {&amp;#10;        var resp = key_resp.corr;&amp;#10;        }&amp;#10;&amp;#10;if ((stim_order == &quot;CS&quot; &amp;&amp; resp == 0)) { // When stimulus order is reversed, response needs to be reversed as well&amp;#10;    resp = 1;&amp;#10;    } else if ((stim_order == &quot;CS&quot;)) {&amp;#10;        resp = 0;&amp;#10;        }&amp;#10;&amp;#10;psychoJS.experiment.addData(&quot;level&quot;, level_array[trial_index]); // Add intensity value to dataset before it is changed.&amp;#10;&amp;#10;// When the response given is longer, add to the decrease counter&amp;#10;if (((resp == 1) &amp;&amp; (level_array[trial_index] &gt;= min_level))) {&amp;#10;    down_counter_array[trial_index] += 1;&amp;#10;    up_counter_array[trial_index] = 0;&amp;#10;}&amp;#10;// When the response given is shorter, add to the increase counter&amp;#10;if (((resp == 0) &amp;&amp; (level_array[trial_index] &lt;= max_level))) {&amp;#10;    up_counter_array[trial_index] += 1;&amp;#10;    down_counter_array[trial_index] = 0;&amp;#10;}&amp;#10;// Once the decrease counter is maxed, decrease the difference&amp;#10;if ((down_counter_array[trial_index] == freq_step_down[freq_index_array[trial_index]])) {&amp;#10;    level_array[trial_index] -= step_size_down[step_index_array[trial_index]];&amp;#10;    current_direction = -1;&amp;#10;    if ((level_array[trial_index] &lt; min_level)) { // Value is set to minimum if it would dip below.&amp;#10;        level_array[trial_index] = min_level;&amp;#10;        }&amp;#10;    down_counter_array[trial_index] = 0; // Trials must be consecutive, so counter is reset&amp;#10;}&amp;#10;// Once the increase counter is maxed, increase the difference&amp;#10;if ((up_counter_array[trial_index] == freq_step_up[freq_index_array[trial_index]])) {&amp;#10;    level_array[trial_index] += step_size_up[step_index_array[trial_index]];&amp;#10;    current_direction = 1;&amp;#10;    if ((level_array[trial_index] &gt; max_level)) { // Value is set to maximum if it would dip above.&amp;#10;        level_array[trial_index] = max_level;&amp;#10;        }&amp;#10;    up_counter_array[trial_index] = 0; // Trials must be consecutive, so counter is reset&amp;#10;}&amp;#10;&amp;#10;// Detects reversals&amp;#10;if ((first_rev_array[trial_index] == 1 &amp;&amp; current_direction != 0 &amp;&amp; current_direction != last_direction_array[trial_index])) { // Up response on last trial/down response on current trial or vice versa&amp;#10;        l_reversal_array[trial_index] = 1; // This trial is a reversal&amp;#10;        n_reversal_array[trial_index] += 1; // Add to total reversal counter&amp;#10;        c_reversal_array[trial_index] += 1; // Add to consecutive reversal counter&amp;#10;        freq_index_array[trial_index] += 1; // Increase step frequency index&amp;#10;        last_direction_array[trial_index] = current_direction;&amp;#10;        if ((step_index_array[trial_index] &gt;= step_size_down.length - 1)) { // Consecutive reversal stop counter&amp;#10;            c_stop_array[trial_index] += 1;&amp;#10;            }&amp;#10;        } else if ((first_rev_array[trial_index] == 1 &amp;&amp; current_direction != 0 &amp;&amp; current_direction == last_direction_array[trial_index])) {&amp;#10;            l_reversal_array[trial_index] = 0; // This trial is NOT a reversal&amp;#10;            c_reversal_array[trial_index] = 0; // Consecutive reversal counter reset&amp;#10;            c_stop_array[trial_index] = 0; // Same as above&amp;#10;            last_direction_array[trial_index] = current_direction;&amp;#10;            } else {&amp;#10;                l_reversal_array[trial_index] = 0; // This trial is NOT a reversal&amp;#10;                }&amp;#10;&amp;#10;if ((first_rev_array[trial_index] == 0 &amp;&amp; current_direction != 0)) {&amp;#10;    first_rev_array[trial_index] = 1;&amp;#10;    last_direction_array[trial_index] = current_direction;&amp;#10;    }&amp;#10;&amp;#10;// Prevent frequency index from exceeding array length&amp;#10;if ((freq_index_array[trial_index] &gt; freq_step_down.length - 1)) {&amp;#10;    freq_index_array[trial_index] = freq_step_down.length - 1;&amp;#10;    }&amp;#10;&amp;#10;// Changes which step size within the step list is being used based on reversals&amp;#10;if (((n_reversal_array[trial_index] &lt;= step_size_down.length - 1) &amp;&amp; (l_reversal_array[trial_index] == 1))) { // Number of reversals is less than step list size, and current trial is a reversal.&amp;#10;    step_index_array[trial_index] += 1; // Move to next value in step list&amp;#10;    } else if (((n_reversal_array[trial_index] &gt; step_size_down.length) &amp;&amp; (l_reversal_array[trial_index] == 1))) { // If reversals have exceeded the step list size&amp;#10;        step_index_array[trial_index] = (step_size_down.length - 1); // Cap step_index at the length of step list&amp;#10;        }&amp;#10;&amp;#10;// Add variables to dataset&amp;#10;psychoJS.experiment.addData(&quot;trial_index&quot;, (trial_index + 1));&amp;#10;psychoJS.experiment.addData(&quot;trial_indexer&quot;, trial_indexer);&amp;#10;psychoJS.experiment.addData(&quot;trial_num&quot;, trial_counter_array[trial_index]);&amp;#10;psychoJS.experiment.addData(&quot;first&quot;, first);&amp;#10;psychoJS.experiment.addData(&quot;second&quot;, second);&amp;#10;psychoJS.experiment.addData(&quot;envelope_1&quot;, env_types[env_array[trial_index]][0]);&amp;#10;psychoJS.experiment.addData(&quot;envelope_2&quot;, env_types[env_array[trial_index]][1]);&amp;#10;psychoJS.experiment.addData(&quot;sound1&quot;, sound1);&amp;#10;psychoJS.experiment.addData(&quot;sound2&quot;, sound2);&amp;#10;psychoJS.experiment.addData(&quot;n_reversal&quot;, n_reversal_array[trial_index]);&amp;#10;psychoJS.experiment.addData(&quot;c_reversal&quot;, c_reversal_array[trial_index]);&amp;#10;psychoJS.experiment.addData(&quot;c_stop&quot;, c_stop_array[trial_index]);&amp;#10;psychoJS.experiment.addData(&quot;l_reversal&quot;, l_reversal_array[trial_index]);&amp;#10;psychoJS.experiment.addData(&quot;t_step_size_up&quot;, step_size_up[step_index_array[trial_index]]);&amp;#10;psychoJS.experiment.addData(&quot;t_step_size_down&quot;, step_size_down[step_index_array[trial_index]]);&amp;#10;psychoJS.experiment.addData(&quot;stim_order&quot;, stim_order);&amp;#10;psychoJS.experiment.addData(&quot;resp&quot;, resp);&amp;#10;psychoJS.experiment.addData(&quot;block&quot;, block_index + 1);&amp;#10;&amp;#10;// Stop parameters&amp;#10;&amp;#10;// When either total reversals or consecutive reversals are reached in a specific staircase, remove it from trials&amp;#10;if (((stop_mode == 1 &amp;&amp; n_reversal_array[trial_index] == stop_num) || (stop_mode == 2 &amp;&amp; c_stop_array[trial_index] == stop_num))) { // Terminate particular trial if total reversal cap is reached&amp;#10;    let index = trial_index_array.indexOf(trial_index);&amp;#10;    if (index &gt; -1) {&amp;#10;        trial_index_array.splice(index, 1);&amp;#10;        }&amp;#10;    if (order_mode &gt; 2 &amp;&amp; order_mode &lt; 6) { // In blocked trials, the staircase index is only increased when the prior staircase is terminated&amp;#10;        trial_indexer += 1;&amp;#10;        trial_index = trial_index_array[trial_indexer -1];&amp;#10;        }&amp;#10;    }&amp;#10;&amp;#10;if ((trial_counter_array[trial_index] == max_trials)) { // Terminate staircase if max trials are reached&amp;#10;    let index = trial_index_array.indexOf(trial_index);&amp;#10;    if (index &gt; -1) {&amp;#10;        trial_index_array.splice(index, 1);&amp;#10;        }&amp;#10;    }&amp;#10;&amp;#10;// When all staircases have been removed, the whole routine is terminated. (unless using interleaved blocks)&amp;#10;if ((trial_index_array.length == 0 &amp;&amp; order_mode != 6)) {&amp;#10;    trials.finished = 1;&amp;#10;    }&amp;#10;&amp;#10;// Different procedure for interleaved blocks - must exhaust all blocks first before experiment is terminated&amp;#10;if (trial_index_array.length == 0 &amp;&amp; order_mode == 6 &amp;&amp; block_index &lt; (block_array.length - 1)) {&amp;#10;    block_index += 1;&amp;#10;    trial_indexer = 0;&amp;#10;    trial_index_array = block_array[block_index];&amp;#10;    break_time = true;&amp;#10;    } else if (order_mode == 6 &amp;&amp; trial_index_array.length == 0 &amp;&amp; block_index == (block_array.length - 1)) {&amp;#10;        trials.finished = 1;&amp;#10;        }&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="thisExp.addData('first', first)&amp;#10;thisExp.addData('second', second)&amp;#10;thisExp.addData('diff', diff)&amp;#10;if key_resp.corr == 1 and diff &gt; min_num:&amp;#10;    step_down_counter += 1&amp;#10;    step_up_counter = 0&amp;#10;if key_resp.corr == 0 and diff &lt; max_num:&amp;#10;    step_up_counter += 1&amp;#10;    step_down_counter = 0&amp;#10;if step_down_counter == freq_step_down:&amp;#10;    diff -= step_size_down&amp;#10;    step_down_counter = 0&amp;#10;if step_up_counter == freq_step_up:&amp;#10;    diff += step_size_up&amp;#10;    step_up_counter = 0" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="trial_setup" valType="code" updates="None" name="name"/>
      </CodeComponent>
